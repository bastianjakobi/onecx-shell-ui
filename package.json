{
  "name": "onecx-shell-root",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "contributors": [
    "OneCX Development Team <onecx_dev@1000kit.org>"
  ],
  "scripts": {
    "install": "bash ./install.sh",
    "build": "bash ./build.sh",
    "build-shell-only": "npm run build --prefix shell",
    "postbuild": "bash ./copy-preloaders.sh",
    "check": "npm run check --prefix shell && rm -rf *.log dist reports .nx pre_loaders/angular*/.nx .angular .eslintcache node_modules/.cache/prettier/.prettier-cache",
    "clean": "npm run clean --prefix shell && rm -rf *.log dist reports .nx pre_loaders/angular*/.nx .angular .eslintcache node_modules/.cache/prettier/.prettier-cache",
    "lint": "npm run lint --prefix shell",
    "format": "npm run format --prefix shell",
    "eslint": "npm run eslint --prefix shell",
    "browser": "npm run browser --prefix shell",
    "prepare": "npm run prepare --prefix shell || true",
    "start": "npm run start --prefix shell",
    "start:local-env": "npm run start:local-env --prefix shell",
    "test": "npm run test --prefix shell",
    "test:ci": "npm run test:ci --prefix shell",
    "sonar": "npm run sonar --prefix shell"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "nx": {
    "includedScripts": []
  }
}
